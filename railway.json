{
  "build": {
    "builder": "railpack",
    "buildCommand": "npm install --build-from-source"
  },
  "start": {
    "startCommand": "npm start"
  },
  "healthcheck": {
    "url": "/api/health",
    "interval": 30
  },
  "serverless": false,
  "restartPolicy": {
    "onFailure": true,
    "maxRetries": 10
  }
}